# AI Studio Environment Variables example template.
# All real production variables MUST be configured within the Settings workflow.

# App URL prefix
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Public Client-Side Configuration
# These are pre-populated from the automated setup and are safe to be public.
VITE_FIREBASE_API_KEY="your_firebase_web_api_key_here"
VITE_FIREBASE_AUTH_DOMAIN="stellar-perigee-498907-c4.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="stellar-perigee-498907-c4"
VITE_FIREBASE_STORAGE_BUCKET="stellar-perigee-498907-c4.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="583548147736"
VITE_FIREBASE_APP_ID="1:583548147736:web:43865ceae5cbbd3dd78b6d"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="ai-studio-36d6feb3-b3c2-4e2a-9c6b-46c7b67a02e9"

# --- Server-side runtime variables (NEVER expose to the client; NEVER commit real values) ---

# Google Gemini API key for server-side AI analysis. OPTIONAL: if unset, analysis falls back to a
# built-in heuristic mock. In production, mount it from a secret manager (e.g. Google Secret Manager).
GEMINI_API_KEY=

# Max time (ms) to wait for a Gemini analysis before falling back to the heuristic. Default 15000.
# Kept under the public route timeout so slow Gemini degrades to a heuristic result, not a 503.
GEMINI_ANALYSIS_TIMEOUT_MS=

# Optional Gemini model id override (analysis + multimodal extraction). Default gemini-3.5-flash.
GEMINI_MODEL=

# --- Sprint 3: private multimodal evidence extraction ---
# Master switch for AI extraction of screenshots/PDFs in PRIVATE authenticated cases. DEFAULT OFF:
# only the literal string "true" enables it. While off, the extract endpoint returns 503. The
# feature is consent-gated and owner-isolated; raw OCR text is never persisted (redacted only).
MULTIMODAL_EXTRACTION_ENABLED=false

# Max time (ms) for one extraction model call before it is treated as a timeout. Default 30000.
MULTIMODAL_EXTRACTION_TIMEOUT_MS=

# Firebase Admin credentials for Firestore + Cloud Storage (server-side). The Admin SDK uses
# Application Default Credentials. Locally, EITHER run `gcloud auth application-default login`
# OR point this at a service-account JSON. Never commit the key file.
# GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account.json"

# Server-side Firestore database id (Firebase Admin). OPTIONAL override; defaults to the provisioned
# AI Studio database id. An empty value falls back to that default and never silently selects the
# Firestore `(default)` database. The CLIENT uses VITE_FIREBASE_FIRESTORE_DATABASE_ID (build-time);
# for a separate staging project set BOTH this and the VITE var to the staging database id.
FIRESTORE_DATABASE_ID=

# Admin allowlist for the Community Signals review dashboard (Phase 4).
# Comma-separated emails. FAIL-CLOSED: if empty/unset, no one is an admin and the
# dashboard is inaccessible (every signed-in user is denied with 403).
# Example: ADMIN_EMAILS="you@example.com,admin@example.com"
ADMIN_EMAILS=
