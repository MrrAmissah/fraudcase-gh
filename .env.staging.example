# FraudCase GH — STAGING environment template (names/placeholders only; NEVER commit real values).
# This documents what staging needs. On Cloud Run, runtime secrets come from Secret Manager and the
# runtime service account (ADC), not from a committed file. VITE_* values are PUBLIC build-time config.

# ============================================================================
# 1. FRONTEND BUILD-TIME (VITE_*) — public by design, inlined into the client bundle at `vite build`.
#    Set these in the staging BUILD environment (CI / docker --build-arg). Do NOT put them in Secret
#    Manager. They must be the STAGING Firebase project's values (a dev-built bundle cannot be promoted).
# ============================================================================
VITE_FIREBASE_API_KEY="<staging-firebase-web-api-key>"
VITE_FIREBASE_AUTH_DOMAIN="<staging-project>.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="<staging-project-id>"
VITE_FIREBASE_STORAGE_BUCKET="<staging-project>.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="<staging-sender-id>"
VITE_FIREBASE_APP_ID="<staging-app-id>"
# Client Firestore database id (build-time). Set to the staging database id (see FIRESTORE_DATABASE_ID).
VITE_FIREBASE_FIRESTORE_DATABASE_ID="<staging-firestore-database-id>"

# ============================================================================
# 2. BACKEND RUNTIME — set on the Cloud Run service (env), not baked into the image.
# ============================================================================
# MUST be production so the server serves dist/ and stays fail-closed (no local-disk evidence fallback).
NODE_ENV=production
# Cloud Run injects PORT automatically; the server honors it (fallback 3000). Usually leave unset.
# PORT=
# True behind the Cloud Run load balancer so client IPs are read correctly.
TRUST_PROXY=true
# Public base URL of the staging service (optional).
APP_URL="https://<staging-host>"

# ============================================================================
# 3. FIREBASE ADMIN / SERVER IDENTITY
# ============================================================================
# On Cloud Run, leave GOOGLE_APPLICATION_CREDENTIALS UNSET: Firebase Admin uses ADC from the runtime
# service account (no service-account JSON key; org policy blocks key creation). Only set this when
# running outside GCP.
# GOOGLE_APPLICATION_CREDENTIALS=
# Server-side Firestore database id. Defaults to the AI Studio id if unset; set explicitly for a
# separate staging project. Empty never silently selects `(default)`.
FIRESTORE_DATABASE_ID="<staging-firestore-database-id>"
# Admin allowlist (only needed if testing admin routes). Comma-separated emails; empty = no admins.
ADMIN_EMAILS=

# ============================================================================
# 4. GEMINI — SERVER-ONLY SECRET
# ============================================================================
# Inject from Secret Manager as a Cloud Run secret. NEVER a build arg, never in the client, never the
# web API key. Without it, extraction/analysis fall back to the deterministic heuristic.
GEMINI_API_KEY="<from-secret-manager>"
# Optional model override (default gemini-3.5-flash) and per-call extraction timeout (ms).
# GEMINI_MODEL=
# MULTIMODAL_EXTRACTION_TIMEOUT_MS=

# ============================================================================
# 5. FEATURE FLAGS — keep OFF for the baseline deploy.
# ============================================================================
# Off for the flag-off baseline. Enable (=true) in STAGING ONLY after the baseline passes, then
# restart/redeploy. Never enable in production until the #19 smoke test is clean.
MULTIMODAL_EXTRACTION_ENABLED=false
# Sprint 2 controls — leave off unless their client integrations are wired (they are not).
# APP_CHECK_ENFORCE=false
# CAPTCHA_ENFORCE=false
# RATE_LIMIT_REDIS_URL=
